# Common Parts Access environment variables
# Copy this file to .env.local and fill in your actual values from your Supabase project.

# Public Supabase project URL from Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Public anonymous key from Supabase Dashboard → Settings → API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key from Supabase Dashboard → Settings → API; server-only, never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Canonical app URL for local or deployed environments; defaults to http://localhost:3000 if omitted.
NEXT_PUBLIC_APP_URL=http://localhost:3000
