# Common Parts Access environment variables
# Copy this file to .env.local and replace every placeholder value.

# Required for local app runtime

# Public Supabase project URL from Supabase Dashboard -> Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Public anonymous key from Supabase Dashboard -> Settings -> API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key from Supabase Dashboard -> Settings -> API; server-only and never exposed client-side.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Canonical app URL used by app metadata; if omitted, code falls back to localhost.
NEXT_PUBLIC_APP_URL=your_app_url_here

# Optional feature flags (set true or false; defaults to false when unset)

# Enables premium-related UI features.
NEXT_PUBLIC_ENABLE_PREMIUM=your_true_or_false_here

# Enables analytics-related UI features.
NEXT_PUBLIC_ENABLE_ANALYTICS=your_true_or_false_here

# Enables comments-related UI features.
NEXT_PUBLIC_ENABLE_COMMENTS=your_true_or_false_here

# Enables ratings-related UI features.
NEXT_PUBLIC_ENABLE_RATINGS=your_true_or_false_here

# Enables social-login-related UI features.
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN=your_true_or_false_here

# Runtime environment name used by framework/runtime checks.
NODE_ENV=your_node_env_here

# Optional edge function and automation variables (required for feedback triage workflow)

# Mistral API key used by triage automation and docs workflow.
MISTRAL_API_KEY=your_mistral_api_key_here

# GitHub token used by automation that creates or updates GitHub issues.
GITHUB_TOKEN=your_github_token_here

# GitHub repository slug in owner/repo format used by triage automation.
GITHUB_REPO=your_github_owner_slash_repo_here

# Supabase project URL for edge functions (typically same as NEXT_PUBLIC_SUPABASE_URL).
SUPABASE_URL=your_supabase_project_url_here

# Shared bearer secret used by the triage webhook caller and receiver.
WEBHOOK_SECRET=your_webhook_secret_here
